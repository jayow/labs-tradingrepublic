# Supabase — from your project's API settings (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER expose with a NEXT_PUBLIC_ prefix or in client code.
# Used for admin author invites + role changes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used for OG tags, sitemap, invite redirect).
# Local dev: http://localhost:3000  ·  Prod: https://labs.tradingrepublic.io
NEXT_PUBLIC_SITE_URL=http://localhost:3000
